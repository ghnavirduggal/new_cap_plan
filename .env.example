# Copy to .env and override as needed.
# ---------------------------------------------------------------------------
# Service URLs (frontend + inter-service)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_FORECAST_URL=http://localhost:8082
# Browser-visible bases (only set these for split-host deployments where the
# browser talks to the backends directly instead of via the Next.js rewrites).
# NEXT_PUBLIC_BROWSER_API_URL=
# NEXT_PUBLIC_BROWSER_FORECAST_URL=
ENGINE_URL=http://localhost:8081
MODELS_URL=http://localhost:8000
# Where "Sign out" sends the user. In a reverse-proxy SSO deployment point this
# at the proxy's logout (e.g. oauth2-proxy: /oauth2/sign_out?rd=/). Unset falls
# back to "/".
# NEXT_PUBLIC_LOGOUT_URL=/oauth2/sign_out?rd=/

# ---------------------------------------------------------------------------
# Data stores
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://cap:cap@localhost:5432/cap_planner?sslmode=disable
# The Python forecast-service reads POSTGRES_DSN (falls back to DATABASE_URL).
# POSTGRES_DSN=postgres://cap:cap@localhost:5432/cap_planner?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Postgres connection pool (forecast-service). POSTGRES_POOL=0 disables pooling.
# POSTGRES_POOL=1
# POSTGRES_POOL_MIN=1
# POSTGRES_POOL_MAX=16

# ---------------------------------------------------------------------------
# CORS — comma-separated explicit allowlist. NEVER use "*" with credentials.
# Applies to both the Go API/engine and the Python forecast-service.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Authentication / authorization (all OFF by default — the app runs without
# auth until these are set). See README "Authentication" for the full flow.
# ---------------------------------------------------------------------------
# Require a valid session token on protected routes (401 otherwise).
# AUTH_ENABLED=1
# Enforce per-plan ownership checks (403 when a non-owner/non-admin accesses).
# AUTHZ_ENABLED=1
# Shared HS256 signing secret. MUST be identical across the Go API and the
# Python forecast-service so one token works on both. Use a long random value.
# AUTH_JWT_SECRET=change-me-to-a-long-random-string
# Trust upstream proxy identity headers (X-Forwarded-Email). Only enable when a
# trusted reverse proxy authenticates the user AND strips client-supplied copies
# of these headers. Required for the /api/auth/token mint endpoint to work.
# TRUST_PROXY_AUTH=1
# Minted session-token lifetime in seconds.
# AUTH_TOKEN_TTL=3600
# Defense-in-depth for the token-mint oracle: when set, proxy-provided identity
# and /api/auth/token are only honored if the request carries a matching
# X-Proxy-Auth header (which the trusted proxy injects and strips from inbound
# client requests). Set the SAME value here and in the proxy. Use a long random
# value. Strongly recommended whenever TRUST_PROXY_AUTH=1.
# PROXY_SHARED_SECRET=change-me-to-a-long-random-string
#
# PRODUCTION BASELINE: set AUTH_ENABLED=1, AUTHZ_ENABLED=1, a strong random
# AUTH_JWT_SECRET, and put the services behind the reverse proxy in
# deploy/reverse-proxy/. Do NOT publish the backend ports (8080/8081/8082/8000)
# or the datastores (5432/6379) to untrusted networks — bind them to localhost
# or an internal Docker network so SSO can't be bypassed by hitting a port.

# ---------------------------------------------------------------------------
# Hardening / limits
# ---------------------------------------------------------------------------
# Max request body the forecast-service accepts (bytes). Default 50 MiB. Enforced
# both up front (Content-Length) and while streaming (defeats chunked bypass).
# MAX_REQUEST_BYTES=52428800
# Max uncompressed size of an uploaded .xlsx (ZIP) before parsing, in bytes —
# guards against decompression "zip bombs". Default 300 MiB.
# MAX_ZIP_UNCOMPRESSED_BYTES=314572800
# Max request body the Go API accepts (bytes). Default 50 MiB.
# MAX_BODY_BYTES=52428800
# Expose the diagnostic /api/planning/plan/debug* endpoints (leak paths/config).
# ENABLE_DEBUG_ENDPOINTS=0

# ---------------------------------------------------------------------------
# Programmatic ingest API (machine-to-machine)
# ---------------------------------------------------------------------------
# Static API key for POST /api/ingest/v1/timeseries. When set, ingest clients
# must send a matching `X-API-Key` header (no interactive JWT/proxy needed). Use
# a long random value. When unset, the ingest API falls back to normal session
# auth. See docs/INGEST_API.md.
# INGEST_API_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Misc cache TTLs (seconds)
# ---------------------------------------------------------------------------
# HEADCOUNT_CACHE_TTL=30
